{
  "manifest_version": 3,
  "name": "Knight",
  "version": "1.0",
  "description": "Protects you from malicious URLs.",

  "permissions": [
    "webNavigation",
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "*://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },

  "icons": {
    "48": "icons/icon48.png"
  }
}
